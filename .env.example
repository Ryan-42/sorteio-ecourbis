# Copie para .env (não commitar) para rodar o server.py localmente com senha.
# Em produção (Render), defina estas mesmas chaves no Dashboard > Environment.

APP_ENV=development

# Gerar com: python gerar_hash.py
ADMIN_PASSWORD_HASH=

# Em produção o Render gera automaticamente via render.yaml (generateValue: true).
# Em dev pode deixar vazio — um valor temporário é gerado a cada start.
SECRET_KEY=

TOKEN_EXPIRE_HORAS=12
